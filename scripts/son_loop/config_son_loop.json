{
  "_comment": "SON-in-the-loop training. Agent learns preferences that work THROUGH SON+A3. Resumes from highway_sonv3 ep600 weights. Target: beat A3-TTT in all scenarios with pp<=0.01.",
  "out_dir": "results/runs/son_loop",
  "seed": 42,
  "episodes": 600,
  "steps_per_episode": 80,
  "son_update_interval": 4,
  "num_ues_cap": 80,
  "epsilon_start": 0.25,
  "epsilon_end": 0.01,
  "epsilon_decay_episodes": 400,
  "lr": 3e-4,
  "lr_min": 1e-6,
  "batch_size": 256,
  "replay_capacity": 200000,
  "gamma": 0.97,
  "tau": 0.005,
  "grad_clip": 1.0,
  "train_every_steps": 4,
  "target_update_every": 500,
  "validate_every": 50,
  "validation_seeds": 3,
  "validation_steps": 60,
  "checkpoint_every": 50,
  "thr_weight": 3.0,
  "p5_weight": 2.0,
  "fairness_weight": 1.5,
  "load_std_penalty": -2.0,
  "pp_penalty": -20.0,
  "ho_cost": -0.3,
  "outage_penalty": -5.0,
  "late_ho_penalty": -1.0,
  "cio_min_db": -6.0,
  "cio_max_db": 6.0,
  "max_cio_step_db": 3.0,
  "base_a3_offset_db": 3.0,
  "base_ttt_steps": 2,
  "preference_threshold": 0.08,
  "rollback_throughput_drop_frac": 0.40,
  "rollback_pingpong_floor": 0.015,
  "train_scenarios": [
    "dense_urban", "highway", "highway_fast", "suburban",
    "sparse_rural", "overloaded_event"
  ],
  "validation_scenarios": ["dense_urban", "highway", "overloaded_event", "suburban"],
  "scenario_sampling_weights": {
    "dense_urban": 1.5,
    "highway": 2.0,
    "highway_fast": 1.5,
    "suburban": 1.0,
    "sparse_rural": 0.7,
    "overloaded_event": 1.5
  },
  "dqn": {
    "hidden_dim": 256,
    "dropout": 0.06,
    "dueling": true,
    "double_dqn": true,
    "use_gat": false,
    "gat_heads": 4
  }
}
